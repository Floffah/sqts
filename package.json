{
    "name": "sqts",
    "private": true,
    "version": "0.0.0",
    "workspaces": [
        "docs",
        "examples/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "lint": "eslint . && turbo typecheck",
        "test": "turbo test",
        "test-examples": "bun run build && turbo test --filter=example-*",
        "check": "bun run lint && bun run build && bun run test"
    },
    "devDependencies": {
        "@arethetypeswrong/core": "^0.18.2",
        "@changesets/changelog-github": "^0.5.2",
        "@changesets/cli": "^2.29.8",
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^10.0.1",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "publint": "^0.3.18",
        "turbo": "^2.8.12",
        "typescript-eslint": "^8.56.1"
    },
    "packageManager": "bun@1.3.10"
}
