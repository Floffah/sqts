{
    "name": "sqts",
    "private": true,
    "version": "0.0.0",
    "workspaces": [
        "examples/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build && turbo lint:package",
        "lint": "eslint . && turbo typecheck",
        "test": "turbo test",
        "test-examples": "bun run build && turbo test --filter=example-*",
        "check": "bun run lint && bun run build && bun run test",
        "release": "bun run build && bun run scripts/workspacerefs.ts"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.2",
        "@arethetypeswrong/core": "^0.18.2",
        "@changesets/changelog-github": "^0.5.2",
        "@changesets/cli": "^2.30.0",
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^10.0.1",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/bun": "^1.3.10",
        "eslint": "^10.0.2",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.1",
        "publint": "^0.3.18",
        "tinyglobby": "^0.2.15",
        "turbo": "^2.8.13",
        "typescript-eslint": "^8.56.1"
    },
    "packageManager": "bun@1.3.10"
}
