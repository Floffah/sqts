{
    "name": "@sqts/sql",
    "version": "0.0.2",
    "description": "SQL utilities for sqts",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Floffah/sqts.git"
    },
    "homepage": "https://floffah.github.io/sqts",
    "license": "MIT",
    "files": [
        "dist",
        "package.json",
        "README.md"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "build": "tsdown --minify",
        "dev": "tsdown --watch",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "lint:package": "attw --pack . && publint --package ."
    },
    "dependencies": {},
    "devDependencies": {
        "@types/bun": "latest",
        "tsdown": "^0.20.3",
        "typescript": "^5.9.3"
    },
    "types": "./dist/index.d.cts",
    "module": "./dist/index.js",
    "main": "./dist/index.cjs",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "default": {
                "types": "./dist/index.d.cts",
                "default": "./dist/index.cjs"
            }
        }
    },
    "publishConfig": {
        "provenance": true
    }
}
